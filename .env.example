DATABASE_URL=file:/home/z/my-project/db/custom.db

# Assistant feature — free Gemini API.
# Get a key at https://aistudio.google.com/apikey
# A standard "AIza..."-prefixed AI Studio key is recommended (free tier works).
# "AQ."-prefixed Vertex AI Express keys also work but require billing on the GCP project.
# Leave empty to disable the Assistant Q&A (the heuristic insights feed still works).
GEMINI_API_KEY=

# Used to sign session cookies. Set to a random 32+ char string in production.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=
