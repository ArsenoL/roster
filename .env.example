DATABASE_URL=file:/home/z/my-project/db/custom.db

# Assistant feature — free Gemini API.
# Get a key at https://aistudio.google.com/apikey
# A standard "AIza..."-prefixed AI Studio key is recommended (free tier works).
# "AQ."-prefixed Vertex AI Express keys also work but require billing on the GCP project.
# Leave empty to disable the Assistant Q&A (the heuristic insights feed still works).
GEMINI_API_KEY=

# Used to sign session cookies. Set to a random 32+ char string in production.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=

# ───── Email / SMTP ─────
# Required to actually send magic-link sign-in emails, notifications, and
# digest emails. If SMTP_HOST is empty (the default), the app runs in
# "dev mailbox" mode:
#   - Emails are NOT delivered over the network.
#   - Each outgoing email is saved as an HTML file under /dev-emails/ in
#     the project root, so you can inspect exactly what would have been sent.
#   - Magic-link sign-in shows a teal "Dev mode" panel with an inline link
#     and a preview of the email HTML, instead of the usual "check your email".
#
# To enable real delivery, fill in the four vars below with your provider's
# credentials. Common providers:
#   - Resend:       SMTP_HOST=smtp.resend.com  SMTP_PORT=465  (secure)
#   - SendGrid:     SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587
#   - Mailgun:      SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
#   - Amazon SES:   SMTP_HOST=email-smtp.us-east-1.amazonaws.com  SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# The From: address used on outgoing mail. Should be on a domain you control
# and that your SMTP provider is authorized to send from.
EMAIL_FROM=Roster <noreply@roster.local>

# Public base URL of the app — used to build absolute links in emails
# (magic-link sign-in, notification deep-links, etc).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

